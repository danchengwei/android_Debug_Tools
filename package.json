{
  "name": "安卓调试工具",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node scripts/start-all.mjs",
    "dev": "node scripts/start-all.mjs",
    "dev:run": "concurrently -n bridge,vite,scrcpy -c cyan,green,magenta \"node --watch adb-server.js\" \"vite\" \"node scrcpy-server.js\"",
    "dev:lite": "node scripts/start-all.mjs --lite",
    "dev:lite:run": "concurrently -k -n bridge,vite -c cyan,green \"node --watch adb-server.js\" \"vite\"",
    "dev:bridge": "node --watch adb-server.js",
    "dev:suppress-adb": "bash start.sh",
    "dev:local": "bash start-local.sh",
    "dev:raw": "vite",
    "dev:win": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@types/express": "^5.0.6",
    "@yume-chan/adb": "^2.5.1",
    "@yume-chan/adb-backend-webusb": "^0.0.19",
    "@yume-chan/struct": "^2.3.2",
    "android-platform-tools": "^3.0.2",
    "express": "^5.2.1",
    "framer-motion": "^12.35.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
